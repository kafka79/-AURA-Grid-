# AURA Grid — Environment Configuration Example
# Copy this file to .env and fill in your values

# ============================================
# Carbon Intensity API (optional)
# Get a free token from https://co2signal.com/
# ============================================
# CARBON_API_TOKEN=your_token_here
# CARBON_API_COUNTRY_CODE=IN

# ============================================
# Solar Forecast API (optional)
# For production: integrate with Solcast, OpenWeather, or NREL
# ============================================
# SOLAR_API_KEY=your_token_here
# SOLAR_API_LATITUDE=28.6139
# SOLAR_API_LONGITUDE=77.2090

# ============================================
# Campus Configuration (optional overrides)
# ============================================
# CAMPUS_LATITUDE=28.6139
# CAMPUS_LONGITUDE=77.2090
# CAMPUS_TIMEZONE_OFFSET=5.5

# ============================================
# Tariff Configuration (optional overrides)
# ============================================
# TARIFF_PEAK_ENERGY_CHARGE=8.50
# TARIFF_STANDARD_ENERGY_CHARGE=6.50
# TARIFF_OFFPEAK_ENERGY_CHARGE=4.50
# TARIFF_DEMAND_CHARGE_PER_KVA=350
# TARIFF_FIXED_CHARGE_PER_MONTH=5000
# TARIFF_GST_RATE=0.18